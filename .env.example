# ==========================================
# RIBOTFLOW - Variables d'Entorn
# Data: 26/05/2026
# ==========================================

# --- Mode d'Aplicació ---
# cloud | self_hosted
NEXT_PUBLIC_APP_MODE=cloud

# --- Base de Dades (PostgreSQL) ---
# Dev (Docker): port 5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ribotflow

# --- Auth.js ---
AUTH_SECRET=change-me-to-a-random-string
AUTH_URL=http://localhost:3000

# --- Redis (Opcional - Cloud: BullMQ / Self-Hosted: pg-boss) ---
REDIS_URL=redis://localhost:6379

# --- Sentry (Observabilitat) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# self_hosted = Sentry desactivat o local
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# --- SMTP (Mailing) ---
# IMPORTANT: key MUST be SMTP_PASSWORD (not SMTP_PASS) - see docs/SMTP_SETUP.md
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# DEV ONLY: accept self-signed certs (e.g. home network intercepting TLS)
# Set to "true" in production to enforce real cert validation
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_REQUIRE_TLS=true

# --- Routing (Geocoding + Distance) ---
ROUTING_GEOCODING_PROVIDER=nominatim
# nominatim | google | openrouteservice
ROUTING_DISTANCE_PROVIDER=haversine
# haversine | google | openrouteservice
GOOGLE_MAPS_API_KEY=
OPENROUTESERVICE_API_KEY=

# --- Google API (Calendar, Drive) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- File Storage ---
STORAGE_PROVIDER=local
# local | minio | supabase

# Local (Development default)
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_URL_PREFIX=/api/uploads

# MinIO (Development via docker-compose.dev.yml)
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ribotflow
MINIO_PUBLIC_URL_BASE=http://localhost:9002/ribotflow

# MinIO (Self-Hosted / Production)
# MINIO_ENDPOINT=minio
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=ribotflow
# MINIO_PUBLIC_URL_BASE=http://localhost:9000/ribotflow

# Supabase (Cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_BUCKET=ribotflow

# --- App Config ---
NEXT_PUBLIC_APP_NAME=RIBOTFLOW
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ==========================================
# RIBOTFLOW - Variables d'Entorn
# Data: 21/05/2026
# ==========================================

# --- Mode d'Aplicació ---
# cloud | self_hosted
NEXT_PUBLIC_APP_MODE=cloud

# --- Base de Dades (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ribotflow

# --- Auth.js ---
AUTH_SECRET=change-me-to-a-random-string
AUTH_URL=http://localhost:3000

# --- Redis (Opcional - Cloud: BullMQ / Self-Hosted: pg-boss) ---
REDIS_URL=redis://localhost:6379

# --- Sentry (Observabilitat) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# self_hosted = Sentry desactivat o local
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# --- SMTP (Mailing) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Google API (Calendar, Drive) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- App Config ---
NEXT_PUBLIC_APP_NAME=RIBOTFLOW
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

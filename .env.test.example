# ==========================================
# RIBOTFLOW - Variables de Test
# Descripción: Variables para ejecutar tests de integración con PostgreSQL.
#              Copia este archivo a .env.test.local y ajusta según tu entorno.
# ==========================================

# --- Base de Datos de Test (obligatorio para tests de integración) ---
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ribotflow_test

# --- Auth.js (mínimo para tests) ---
AUTH_SECRET=test-secret-key-minimum-32-chars-long

# --- Modo de Aplicación (cloud | self_hosted) ---
NEXT_PUBLIC_APP_MODE=cloud

# --- App Config ---
NODE_ENV=test

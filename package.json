    "db:push": "drizzle-kit push",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.0",
